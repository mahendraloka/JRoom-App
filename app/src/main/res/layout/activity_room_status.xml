<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNamaRuangan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nama Ruangan"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1E1E1E"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvInfoTambahan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Info tambahan"
            android:textColor="#666666"
            android:layout_marginBottom="16dp"
            android:textAppearance="?android:attr/textAppearanceMedium" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="8dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#FFFFFF">

            <CalendarView
                android:id="@+id/calendarView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="#FFFFFF"/>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="* Tanggal yang ditandai berarti sudah dibooking."
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Jadwal Booking:"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#1E1E1E"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvStatusTanggal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:textColor="#444444" />

        <LinearLayout
            android:id="@+id/layoutBookingList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="24dp"
            android:elevation="2dp" />
    </LinearLayout>
</ScrollView>
