<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="24dp"
        android:elevation="4dp">

        <!-- Judul -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Form Booking Ruangan"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="24dp" />

        <!-- Nama Pemesan -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Pemesan"
            android:textColor="#555" />

        <EditText
            android:id="@+id/etNamaPemesan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColorHint="#99000000"
            android:textColor="#000000"
            android:hint="Masukkan nama anda"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <!-- Pilih Ruangan -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pilih Ruangan"
            android:textColor="#555" />

        <Spinner
            android:id="@+id/spinnerRuangan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:theme="@style/ThemeOverlay.AppCompat.Light"/>

        <!-- Tanggal Booking -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tanggal Booking"
            android:textColor="#555" />

        <Button
            android:id="@+id/btnPilihTanggal"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pilih Tanggal"
            android:backgroundTint="#3F51B5"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- Waktu Mulai -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waktu Mulai"
            android:textColor="#555" />

        <Button
            android:id="@+id/btnWaktuMulai"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pilih Waktu Mulai"
            android:backgroundTint="#3F51B5"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- Waktu Selesai -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waktu Selesai"
            android:textColor="#555" />

        <Button
            android:id="@+id/btnWaktuSelesai"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pilih Waktu Selesai"
            android:backgroundTint="#3F51B5"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- Tujuan -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tujuan Booking"
            android:textColor="#555" />

        <EditText
            android:id="@+id/etTujuan"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:textColorHint="#99000000"
            android:textColor="#000000"
            android:hint="Masukkan tujuan booking"
            android:gravity="top"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <!-- Submit -->
        <Button
            android:id="@+id/btnSubmit"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Submit Booking"
            android:textColor="#FFFFFF"
            android:backgroundTint="#009688"
            android:paddingVertical="12dp" />

        <TextView
            android:id="@+id/tvSelectedData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:textColor="#333" />
    </LinearLayout>
</ScrollView>
