<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Judul -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dashboard JRoom"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="32dp" />

        <!-- Tombol Card -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp">

            <Button
                android:id="@+id/btnCheckAvailability"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cek Ketersediaan"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#3F51B5"
                android:layout_marginBottom="16dp"
                android:paddingVertical="12dp" />

            <Button
                android:id="@+id/btnBooking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Booking Ruangan"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#009688"
                android:layout_marginBottom="16dp"
                android:paddingVertical="12dp" />

            <Button
                android:id="@+id/btnRiwayat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Riwayat Peminjaman"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9800"
                android:layout_marginBottom="16dp"
                android:paddingVertical="12dp" />

            <Button
                android:id="@+id/btnKalenderAkademik"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cek Kalender Akademik"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#9C27B0"
                android:paddingVertical="12dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
